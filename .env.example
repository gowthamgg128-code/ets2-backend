# Database Configuration
DATABASE_URL=postgresql+psycopg://user:password@host:5432/database

# JWT Configuration
SECRET_KEY=your-super-secret-key-min-32-characters-here-change-this-in-production
MASTER_SECRET=very_long_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Launcher Encryption Compatibility
LAUNCHER_SALT=ETS2_LAUNCHER_SALT_V1

# Application Configuration
DEBUG=false

# GitHub Releases Storage
GITHUB_STORAGE_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_STORAGE_REPO=owner/repository
GITHUB_API_URL=https://api.github.com
